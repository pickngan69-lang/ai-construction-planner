# Copy to `.env` and set your PostgreSQL / Supabase connection string.
#
# ── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → Database → Connection string (URI)
#   • Runtime (แอป):  ใช้ Connection Pooler (port 6543, Transaction mode)
#   • Migrations:     ใช้ Direct connection (port 5432)  ← pooler รัน DDL ไม่ได้
# ต้องเป็น postgresql:// (ไม่ใช่ postgres://) — app.py เติม sslmode=require ให้อัตโนมัติ
#
# ตัวอย่าง Supabase (pooler, สำหรับรันแอป):
# DATABASE_URL=postgresql://postgres.abcdxyz:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# ── Local dev (Docker) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_db
