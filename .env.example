# Copy this file to `.env.local` for local development.
# Do not commit real keys.

# Anthropic API key: server-side only. Do NOT add VITE_ prefix.
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Supabase browser/client key. Safe for frontend when RLS policies are correct.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase backend/admin key. Server-side only. Do NOT add VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Opn/Omise payment gateway
OMISE_PUBLIC_KEY=pkey_test_xxxxx
OMISE_SECRET_KEY=skey_test_xxxxx
OMISE_WEBHOOK_SECRET=
APP_URL=http://localhost:5173
